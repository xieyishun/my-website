---
import type { CollectionEntry } from 'astro:content';
import FormattedDate from './FormattedDate.astro';
import { withBase } from '../utils/url';

interface RelatedItem {
  post: CollectionEntry<'blog'>;
  score: number;
  shared: {
    series: string[];
    tags: string[];
    sameGame: boolean;
  };
}

interface Props {
  items: RelatedItem[];
}

const { items } = Astro.props;
---

{items.length > 0 && (
  <section class="related">
    <h2 class="related-title">
      <span class="title-deco" aria-hidden="true"></span>
      你可能也会感兴趣
    </h2>
    <ul class="related-list">
      {items.map(({ post, shared }) => {
        const desc = String((post.data as any).summary ?? (post.data as any).description ?? '').trim();
        const reasons = [
          ...shared.series.map((s) => `专题：${s}`),
          ...shared.tags.slice(0, 2).map((t) => `# ${t}`),
          shared.sameGame ? `同游戏` : null,
        ].filter(Boolean) as string[];

        return (
          <li class="related-item">
            <a class="related-link" href={withBase(`/blog/${post.id}/`)}>
              <h3 class="related-h">{post.data.title}</h3>
              {desc && <p class="related-desc">{desc}</p>}
              <div class="related-foot">
                <span class="related-date">
                  <FormattedDate date={post.data.pubDate} />
                </span>
                <div class="related-reasons">
                  {reasons.slice(0, 3).map((r) => (
                    <span class="related-chip">{r}</span>
                  ))}
                </div>
              </div>
            </a>
          </li>
        );
      })}
    </ul>
  </section>
)}

<style is:global>
  .related {
    margin: 3rem 0 1rem 0;
    padding-top: 2rem;
    border-top: 1px solid rgba(var(--gray-light), 1);
  }

  .related-title {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    margin: 0 0 1.25rem 0;
    font-size: 1.35rem;
    font-weight: 600;
  }

  .title-deco {
    width: 4px;
    height: 1.2em;
    background: linear-gradient(180deg, #2337ff 0%, #785aff 100%);
    border-radius: 2px;
  }

  .related-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
    gap: 1rem;
  }

  .related-item {
    margin: 0;
  }

  .related-link {
    display: block;
    height: 100%;
    padding: 1rem 1.1rem;
    background: #fff;
    border: 1px solid rgba(var(--gray-light), 1);
    border-radius: 12px;
    text-decoration: none;
    color: inherit;
    transition: transform 0.18s ease, border-color 0.18s ease, box-shadow 0.18s ease;
  }

  .related-link:hover {
    transform: translateY(-3px);
    border-color: rgba(35, 55, 255, 0.4);
    box-shadow: 0 8px 20px rgba(35, 55, 255, 0.08);
  }

  .related-h {
    margin: 0 0 0.4rem 0;
    font-size: 1rem;
    line-height: 1.4;
    font-weight: 600;
    color: rgb(var(--black));
  }

  .related-link:hover .related-h {
    color: var(--accent);
  }

  .related-desc {
    margin: 0 0 0.75rem 0;
    color: rgb(var(--gray));
    font-size: 0.85rem;
    line-height: 1.55;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .related-foot {
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .related-date {
    font-size: 0.78rem;
    color: rgb(var(--gray));
  }

  .related-reasons {
    display: flex;
    gap: 0.3rem;
    flex-wrap: wrap;
  }

  .related-chip {
    font-size: 0.72rem;
    padding: 0.1rem 0.5rem;
    background: rgba(35, 55, 255, 0.08);
    color: var(--accent-dark);
    border-radius: 999px;
  }

  @media (prefers-reduced-motion: reduce) {
    .related-link { transition: none; }
    .related-link:hover { transform: none; }
  }
</style>
