---
// 社交/联系方式图标链接组
// size: 图标大小 (px)
interface Props {
  size?: number;
  class?: string;
}
const { size = 20, class: className = '' } = Astro.props;

const links = [
  {
    name: 'Email',
    href: 'mailto:xieyishun@126.com',
    label: '发邮件给我',
    rel: '',
  },
  {
    name: 'GitHub',
    href: 'https://github.com/xieyishun',
    label: '我的 GitHub',
    rel: 'noopener noreferrer',
  },
];
---

<ul class={`social-links ${className}`}>
  {links.map((link) => (
    <li>
      <a
        href={link.href}
        aria-label={link.label}
        title={link.label}
        target={link.name === 'Email' ? undefined : '_blank'}
        rel={link.rel || undefined}
      >
        {link.name === 'Email' && (
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width={size}
            height={size}
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            aria-hidden="true"
          >
            <rect x="3" y="5" width="18" height="14" rx="2" />
            <path d="m3 7 9 6 9-6" />
          </svg>
        )}
        {link.name === 'GitHub' && (
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width={size}
            height={size}
            viewBox="0 0 24 24"
            fill="currentColor"
            aria-hidden="true"
          >
            <path d="M12 .5C5.65.5.5 5.65.5 12c0 5.08 3.29 9.39 7.86 10.91.58.1.79-.25.79-.56v-2.17c-3.2.7-3.87-1.37-3.87-1.37-.52-1.33-1.28-1.69-1.28-1.69-1.05-.72.08-.71.08-.71 1.16.08 1.77 1.19 1.77 1.19 1.03 1.77 2.7 1.26 3.36.96.1-.74.4-1.26.73-1.55-2.55-.29-5.24-1.28-5.24-5.7 0-1.26.45-2.29 1.18-3.1-.12-.29-.51-1.46.11-3.05 0 0 .97-.31 3.18 1.18a11.05 11.05 0 0 1 5.78 0c2.21-1.49 3.18-1.18 3.18-1.18.62 1.59.23 2.76.11 3.05.74.81 1.18 1.84 1.18 3.1 0 4.43-2.7 5.41-5.27 5.69.41.36.78 1.06.78 2.14v3.17c0 .31.21.67.8.56C20.21 21.39 23.5 17.08 23.5 12 23.5 5.65 18.35.5 12 .5z" />
          </svg>
        )}
        <span class="sr-only">{link.label}</span>
      </a>
    </li>
  ))}
</ul>

<style>
  .social-links {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    gap: 0.5rem;
    align-items: center;
  }

  .social-links a {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 38px;
    height: 38px;
    border-radius: 10px;
    color: rgb(var(--gray-dark));
    background: rgba(var(--gray-light), 0.6);
    transition: transform 0.18s ease, background 0.18s ease, color 0.18s ease;
    text-decoration: none;
  }

  .social-links a:hover {
    transform: translateY(-2px);
    background: var(--accent);
    color: #fff;
  }

  .social-links a:focus-visible {
    outline: 2px solid var(--accent);
    outline-offset: 2px;
  }
</style>
