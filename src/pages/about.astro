---
import Layout from '../layouts/BlogPost.astro';
import Avatar from '../components/Avatar.astro';
import SocialLinks from '../components/SocialLinks.astro';
---

<Layout
	type="note"
	title="关于我 | About Me"
	description="Xie Yi - Hult Business Data Analysis Student"
	series={[]}
	tags={[]}
	game=""
	region={[]}
	summary="关于我页面"
	pubDate={new Date('2026-01-12')}
>
	<section class="about-hero">
		<div class="about-avatar">
			<div class="avatar-halo" aria-hidden="true"></div>
			<Avatar size={130} />
		</div>
		<div class="about-intro">
			<p class="about-eyebrow">
				<span class="dot" aria-hidden="true"></span>
				Boston · 商业数据分析 · 游戏运营
			</p>
			<h1 class="about-name">你好，我是刀刀 👋</h1>
			<p class="about-tagline">
				一名研究生，主修 <strong>商业数据分析（Master of Business Data Analysis）</strong>，
				热爱用数据视角看游戏。
			</p>
			<div class="about-socials">
				<SocialLinks />
			</div>
		</div>
	</section>

	<section class="about-block">
		<h2 class="block-title">
			<span class="block-emoji" aria-hidden="true">🎯</span>
			为什么做这个网站
		</h2>
		<p class="block-text">
			我对 <strong>游戏行业</strong> 充满热情，特别是
			<strong>游戏运营（Game Ops）</strong> 和 <strong>游戏拆解（Deconstruction）</strong>。
			建立这个网站是为了记录我从数据视角看游戏的过程——
			我相信数据不仅能验证直觉，更能发现潜在的增长机会。
		</p>
	</section>

	<section class="about-block">
		<h2 class="block-title">
			<span class="block-emoji" aria-hidden="true">🛠️</span>
			我的技能栈
		</h2>
		<div class="skill-grid">
			<div class="skill-card">
				<div class="skill-card-head">数据分析</div>
				<div class="skill-tags">
					<span class="skill-tag">SQL</span>
					<span class="skill-tag">Python</span>
					<span class="skill-tag">Tableau</span>
				</div>
			</div>
			<div class="skill-card">
				<div class="skill-card-head">游戏业务</div>
				<div class="skill-tags">
					<span class="skill-tag">玩法拆解</span>
					<span class="skill-tag">经济系统</span>
					<span class="skill-tag">用户留存</span>
				</div>
			</div>
			<div class="skill-card">
				<div class="skill-card-head">其他</div>
				<div class="skill-tags">
					<span class="skill-tag">Astro</span>
					<span class="skill-tag">Git / GitHub</span>
					<span class="skill-tag">Godot（学习中）</span>
				</div>
			</div>
		</div>
	</section>

	<section class="about-block">
		<h2 class="block-title">
			<span class="block-emoji" aria-hidden="true">📫</span>
			联系我
		</h2>
		<p class="block-text">
			如果你对我的文章感兴趣，或者有合作机会，欢迎随时联系我！
		</p>
		<div class="contact-row">
			<a class="contact-pill" href="mailto:xieyishun@126.com">
				<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
					<rect x="3" y="5" width="18" height="14" rx="2" />
					<path d="m3 7 9 6 9-6" />
				</svg>
				<span>xieyishun@126.com</span>
			</a>
			<a class="contact-pill" href="https://github.com/xieyishun" target="_blank" rel="noopener noreferrer">
				<svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
					<path d="M12 .5C5.65.5.5 5.65.5 12c0 5.08 3.29 9.39 7.86 10.91.58.1.79-.25.79-.56v-2.17c-3.2.7-3.87-1.37-3.87-1.37-.52-1.33-1.28-1.69-1.28-1.69-1.05-.72.08-.71.08-.71 1.16.08 1.77 1.19 1.77 1.19 1.03 1.77 2.7 1.26 3.36.96.1-.74.4-1.26.73-1.55-2.55-.29-5.24-1.28-5.24-5.7 0-1.26.45-2.29 1.18-3.1-.12-.29-.51-1.46.11-3.05 0 0 .97-.31 3.18 1.18a11.05 11.05 0 0 1 5.78 0c2.21-1.49 3.18-1.18 3.18-1.18.62 1.59.23 2.76.11 3.05.74.81 1.18 1.84 1.18 3.1 0 4.43-2.7 5.41-5.27 5.69.41.36.78 1.06.78 2.14v3.17c0 .31.21.67.8.56C20.21 21.39 23.5 17.08 23.5 12 23.5 5.65 18.35.5 12 .5z" />
				</svg>
				<span>github.com/xieyishun</span>
			</a>
		</div>
	</section>
</Layout>

<style>
	.about-hero {
		display: flex;
		align-items: center;
		gap: 2rem;
		padding: 1.5rem 0 2rem 0;
		margin-bottom: 1.5rem;
		border-bottom: 1px solid rgba(var(--gray-light), 1);
	}

	.about-avatar {
		position: relative;
		flex-shrink: 0;
		width: 150px;
		height: 150px;
		display: flex;
		align-items: center;
		justify-content: center;
	}

	.avatar-halo {
		position: absolute;
		inset: -8px;
		border-radius: 50%;
		background: radial-gradient(circle, rgba(35, 55, 255, 0.18) 0%, rgba(35, 55, 255, 0) 70%);
		animation: halo 4s ease-in-out infinite;
	}

	@keyframes halo {
		0%, 100% { transform: scale(1); opacity: 0.8; }
		50% { transform: scale(1.08); opacity: 1; }
	}

	@media (prefers-reduced-motion: reduce) {
		.avatar-halo { animation: none; }
	}

	.about-intro { flex: 1; min-width: 0; }

	.about-eyebrow {
		display: inline-flex;
		align-items: center;
		gap: 0.5rem;
		margin: 0 0 0.5rem 0;
		padding: 0.3rem 0.75rem;
		font-size: 0.82rem;
		color: rgb(var(--gray-dark));
		background: rgba(var(--gray-light), 0.7);
		border-radius: 999px;
		font-weight: 500;
	}

	.about-eyebrow .dot {
		width: 6px;
		height: 6px;
		border-radius: 50%;
		background: var(--accent);
	}

	.about-name {
		margin: 0 0 0.6rem 0;
		font-size: 1.85rem;
		line-height: 1.25;
		font-weight: 700;
	}

	.about-tagline {
		margin: 0 0 1rem 0;
		color: rgb(var(--gray-dark));
		font-size: 1.02rem;
		line-height: 1.6;
	}

	.about-socials { margin-top: 0.5rem; }

	.about-block { margin: 2rem 0; }

	.block-title {
		display: inline-flex;
		align-items: center;
		gap: 0.55rem;
		margin: 0 0 0.85rem 0;
		font-size: 1.2rem;
		font-weight: 600;
	}

	.block-emoji { font-size: 1.15rem; line-height: 1; }
	.block-text { margin: 0; color: rgb(var(--gray-dark)); line-height: 1.8; }

	.skill-grid {
		display: grid;
		grid-template-columns: repeat(3, 1fr);
		gap: 1rem;
		margin-top: 0.5rem;
	}

	.skill-card {
		padding: 1rem 1.1rem;
		background: #fff;
		border: 1px solid rgba(var(--gray-light), 1);
		border-radius: 12px;
		transition: transform 0.18s ease, border-color 0.18s ease, box-shadow 0.18s ease;
	}

	.skill-card:hover {
		transform: translateY(-3px);
		border-color: rgba(35, 55, 255, 0.3);
		box-shadow: 0 6px 18px rgba(35, 55, 255, 0.08);
	}

	.skill-card-head {
		font-size: 0.78rem;
		color: rgb(var(--gray));
		letter-spacing: 0.05em;
		text-transform: uppercase;
		margin-bottom: 0.6rem;
	}

	.skill-tags { display: flex; flex-wrap: wrap; gap: 0.4rem; }

	.skill-tag {
		padding: 0.2rem 0.6rem;
		font-size: 0.85rem;
		background: rgba(35, 55, 255, 0.08);
		color: var(--accent-dark);
		border-radius: 6px;
		font-weight: 500;
	}

	.contact-row {
		display: flex;
		flex-wrap: wrap;
		gap: 0.75rem;
		margin-top: 0.5rem;
	}

	.contact-pill {
		display: inline-flex;
		align-items: center;
		gap: 0.5rem;
		padding: 0.55rem 1rem;
		background: rgba(var(--gray-light), 0.6);
		color: rgb(var(--gray-dark));
		border-radius: 10px;
		text-decoration: none;
		font-size: 0.95rem;
		font-weight: 500;
		transition: transform 0.18s ease, background 0.18s ease, color 0.18s ease;
	}

	.contact-pill:hover {
		transform: translateY(-2px);
		background: var(--accent);
		color: #fff;
	}

	@media (max-width: 720px) {
		.about-hero {
			flex-direction: column;
			align-items: flex-start;
			text-align: left;
			gap: 1.25rem;
		}
		.about-avatar { width: 110px; height: 110px; }
		.about-name { font-size: 1.6rem; }
		.skill-grid { grid-template-columns: 1fr; }
	}
</style>
